# Copy to .env or export variables in your shell.
AGENT_BUS_DB=/home/aspa/agent-bus/data/agent-bus.sqlite3
AGENT_BUS_HOST=127.0.0.1
AGENT_BUS_PORT=8765

# Optional. If unset, events are stored but not sent to Discord.
DISCORD_WEBHOOK_URL=

# Optional shared secret for write APIs. Leave empty for local-only MVP.
AGENT_BUS_TOKEN=

# Optional default base URL used by agentctl.
AGENT_BUS_URL=http://127.0.0.1:8765
